{
  "name": "supabase-mcp",
  "command": "npx",
  "args": ["@modelcontextprotocol/server-supabase"],
  "env": {
    "SUPABASE_ACCESS_TOKEN": "YOUR_TOKEN",
    "SUPABASE_PROJECT_ID": "YOUR_PROJECT_ID",
    "SUPABASE_URL": "${SUPABASE_URL}",
    "SUPABASE_SERVICE_ROLE_KEY": "${SUPABASE_SERVICE_ROLE_KEY}"
  },
  "options": { "stdio": "pipe" }
}
