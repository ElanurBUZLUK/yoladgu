{
  "server": {
    "name": "huggingface-mcp",
    "version": "1.0.0",
    "description": "HuggingFace MCP Server Configuration",
    "capabilities": {
      "models": ["text-generation", "text-classification", "translation"],
      "max_tokens": 2048,
      "temperature": 0.7
    },
    "auth": {
      "type": "token",
      "env_var": "HF_TOKEN"
    }
  }
} 