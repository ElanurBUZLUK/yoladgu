# Yoladgu - AI-Powered Question Recommendation System
# Environment Variables Template
# Copy this file to .env and fill in your actual values

# === REQUIRED SECURITY SETTINGS ===
# Generate a strong secret key for JWT tokens (keep this secret!)
# You can generate one using: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-super-secure-secret-key-here-please-change-this

# === REQUIRED DATABASE SETTINGS ===
# PostgreSQL Configuration
POSTGRES_SERVER=localhost
POSTGRES_USER=your_db_username
POSTGRES_PASSWORD=your_secure_db_password
POSTGRES_DB=yoladgu
# Optional: If you want to provide the full DATABASE_URL instead
# DATABASE_URL=postgresql://user:password@localhost:5432/database

# === REQUIRED NEO4J SETTINGS ===
# Neo4j Graph Database Configuration
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

# === OPTIONAL REDIS SETTINGS ===
# Redis Configuration (for caching and rate limiting)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=your_redis_password  # Uncomment if Redis requires auth

# === OPTIONAL LLM API KEYS ===
# OpenAI Configuration (required if using OpenAI provider)
# OPENAI_API_KEY=sk-your-openai-api-key-here

# Hugging Face Configuration (required if using Hugging Face models)
# HUGGINGFACE_API_TOKEN=hf_your-huggingface-token-here

# === APPLICATION SETTINGS ===
# Environment: development, staging, production
ENVIRONMENT=development

# Project Settings
PROJECT_NAME=Question Recommendation System
API_V1_STR=/api/v1

# === FEATURE FLAGS ===
# Enable/disable features
USE_NEO4J=true
USE_EMBEDDING=true
USE_DIVERSITY_FILTER=true
USE_ENSEMBLE_SCORING=true
RATE_LIMIT_ENABLED=true

# === LOGGING ===
LOG_LEVEL=INFO
LOG_FORMAT=json

# === PERFORMANCE TUNING ===
# Vector Store Performance
HNSW_M=16
HNSW_EF_CONSTRUCTION=200
HNSW_EF_SEARCH=100

# Connection Pool Settings
ASYNCPG_MIN_SIZE=5
ASYNCPG_MAX_SIZE=20
ASYNCPG_TIMEOUT=30

# Cache TTL Settings (in seconds)
CACHE_DEFAULT_TTL=300
CACHE_EMBEDDING_TTL=3600
CACHE_SEARCH_TTL=600

# === SECURITY NOTES ===
# 1. Never commit the actual .env file to version control
# 2. Use strong, unique passwords for all services
# 3. Generate a cryptographically secure SECRET_KEY
# 4. In production, consider using a secrets management service
# 5. Rotate credentials regularly
# 6. Use different credentials for different environments
