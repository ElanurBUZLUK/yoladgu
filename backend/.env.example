# App
PROJECT_NAME=LearnAI
API_V1_STR=/api/v1
JWT_SECRET=supersecretjwt
JWT_ALG=HS256
ACCESS_TOKEN_EXPIRE_MIN=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# DB
DATABASE_URL=postgresql+asyncpg://learnai:learnai@localhost:5432/learnai

# Redis
REDIS_URL=redis://localhost:6379/0

# Vector/Index
VECTOR_BACKEND=hnsw  # hnsw | faiss | qdrant
VECTOR_INDEX_DIR=../data/indices
VECTOR_ACTIVE_KEY=vector:index:active
VECTOR_BLUE_NAME=blue
VECTOR_GREEN_NAME=green
VECTOR_STORE_TOMBSTONE_KEY=vector:tombstones
EMBED_DIM=384

# HNSW
HNSW_SPACE=l2
HNSW_M=64
HNSW_EF_CONSTRUCT=200
HNSW_EF_SEARCH=64

# FAISS
FAISS_NLIST=100
FAISS_PQ_M=48
FAISS_PQ_BITS=8
FAISS_NPROBE=8

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_BLUE=questions_blue
QDRANT_COLLECTION_GREEN=questions_green
QDRANT_ALIAS_ACTIVE=questions_active

