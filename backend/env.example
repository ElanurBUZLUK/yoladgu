# ====== Core ======
PROJECT_NAME=LearnAI
API_V1_STR=/api/v1
ENV=dev

# ====== Auth ======
JWT_SECRET=change_me_in_prod
JWT_ALG=HS256
ACCESS_TOKEN_EXPIRE_MIN=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ====== DB / Cache ======
DATABASE_URL=postgresql+asyncpg://yoladgu:password@postgres:5432/yoladgu
REDIS_URL=redis://redis:6379/0

# ====== CORS ======
# Comma-separated origins, e.g. https://app.example.com,https://admin.example.com
CORS_ALLOW_ORIGINS=http://localhost:8080

# ====== Vector Backends ======
VECTOR_BACKEND=hnsw  # hnsw|faiss|qdrant
VECTOR_INDEX_DIR=../data/indices
VECTOR_ACTIVE_KEY=vector:index:active
VECTOR_BLUE_NAME=blue
VECTOR_GREEN_NAME=green
VECTOR_STORE_TOMBSTONE_KEY=vector:tombstones
EMBED_DIM=384

# HNSW
HNSW_SPACE=l2
HNSW_M=64
HNSW_EF_CONSTRUCT=200
HNSW_EF_SEARCH=64

# FAISS
FAISS_NLIST=100
FAISS_PQ_M=48
FAISS_PQ_BITS=8
FAISS_NPROBE=8

# QDRANT
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION_BLUE=questions_blue
QDRANT_COLLECTION_GREEN=questions_green
QDRANT_ALIAS_ACTIVE=questions_active

# ====== Embeddings ======
EMBEDDING_PROVIDER=hash  # openai|cohere|sbert|hash
EMBEDDING_MODEL=
EMBEDDING_MODEL_ID=text-embedding-3-small
EMBEDDING_DIM=384


